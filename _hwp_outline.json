    },
    {
      "level": "heuristic",
      "style_id": 0,
      "style_name": "바탕글",
      "text": "■ 탈도사의 원포인트레슨_직업분석편_커피숍과 까페"
    },
    {
      "level": "heuristic",
      "style_id": 0,
      "style_name": "바탕글",
